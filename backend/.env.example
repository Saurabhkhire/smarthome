OPENAI_API_KEY=sk-...
DEEPL_API_KEY=
DB_PATH=./listings.db

SCRAPER_AI_AUTH=
EXTRACT_API_URL=https://sgai-api-v2.onrender.com/api/v1/extract
TELEGRAM_BOT_TOKEN=

# --- Resend (recommended) https://resend.com/api-keys ---
RESEND_API_KEY=re_xxxxxxxx
# Default from is onboarding@resend.dev (testing). For production: verify domain, then e.g.
# RESEND_FROM=Aria <notifications@yourdomain.com>
RESEND_FROM=Aria <onboarding@resend.dev>

# --- Gmail SMTP (optional fallback if Resend fails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Health: GET http://127.0.0.1:8000/health/smtp  -> email_ready, resend_ready
